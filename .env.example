# Connect With Bayezid - Environment Configuration
# ================================================
# Copy this file to .env and update with your actual values

# Manus Backend Configuration
# Replace with your actual Manus backend URL
# Example: https://3000-xxx.manus.computer/api/trpc
MANUS_BACKEND_URL=https://your-manus-backend.com/api/trpc

# API Endpoints (optional - only if different from defaults)
# INQUIRIES_ENDPOINT=inquiries.submit
# SERVICE_ORDERS_ENDPOINT=serviceOrders.submit
# NEWSLETTERS_ENDPOINT=newsletters.subscribe
# FEEDBACK_ENDPOINT=feedback.submit
# SERVICES_ENDPOINT=services.list

# Request Configuration
API_TIMEOUT=10000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=1000

# Application Settings
APP_NAME=Connect With Bayezid
APP_VERSION=1.0.0
APP_ENVIRONMENT=production

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_FORM_VALIDATION=true
ENABLE_AUTO_SAVE=false

# Notification Settings
NOTIFICATION_DURATION=5000
NOTIFICATION_POSITION=top-right

# Email Configuration (for backend)
SMTP_HOST=your-smtp-host.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@connectwithbayezid.com
OWNER_EMAIL=owner@connectwithbayezid.com

# Database Configuration (for backend)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bayezid_db
DB_USER=root
DB_PASSWORD=your-password

# Analytics (optional)
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
HOTJAR_ID=your-hotjar-id

# Social Media Links
LINKEDIN_URL=https://linkedin.com/in/sayadbayezid
TWITTER_URL=https://twitter.com/sayadbayezid
GITHUB_URL=https://github.com/bayeziddev
FACEBOOK_URL=https://facebook.com/sayadbayezid
INSTAGRAM_URL=https://instagram.com/sayadbayezid
